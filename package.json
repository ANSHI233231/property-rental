{
  "name": "gharsetu",
  "private": true,
  "version": "0.0.0",
  "description": "GharSetu — Delhi-first property rental management platform (monorepo root).",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./apps/**\" build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:db": "docker compose up -d postgres",
    "dev:db:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.0.2",
      "file-type": ">=21.3.2",
      "path-to-regexp": ">=0.1.13",
      "lodash": ">=4.18.0",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    }
  }
}
