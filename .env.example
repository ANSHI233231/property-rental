# GharSetu — environment variables
# Copy this file to `apps/api/.env` and fill in real values for local dev.
# NEVER commit a real `.env`.

# ---- API (apps/api) ----
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0

# Database — docker-compose maps Postgres 18 to host port 5433
# (5432 is intentionally avoided to not clash with a host-installed Postgres).
DATABASE_URL=postgresql://gharsetu:gharsetu_dev_pw@localhost:5433/gharsetu?schema=public

# Scheduler — background cron jobs (BL-12, BL-13, BL-17) run in-process via
# @nestjs/schedule. For multi-instance deployments, set RUN_SCHEDULER=false on
# any replica that should NOT run cron triggers to avoid duplicate runs.
# Default (unset) enables the scheduler.
# RUN_SCHEDULER=true

# JWT (Phase 1)
# HS256 secret — minimum 32 random bytes. Generate: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_32_random_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed (Phase 1)
# Bootstrap admin account — set these before running `pnpm prisma db seed`
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me_min10chars_with_letter_and_number

# Test users (PM, Maintenance, Tenant) — used ONLY in dev/test environments
SEED_TEST_PASSWORD=change_me_min10chars_with_letter_and_number

# CORS — origin allowed to call the API (dev: Next.js dev server)
WEB_ORIGIN=http://localhost:3000

# ---- Web (apps/web) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
