# GharSetu — environment variables (Phase 0)
# Copy this file to `.env` (in apps/api/) and fill in real values for local dev.
# NEVER commit a real `.env`.

# ---- API (apps/api) ----
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0

# Database — docker-compose maps Postgres 18 to host port 5433
# (5432 is intentionally avoided to not clash with a host-installed Postgres).
DATABASE_URL=postgresql://gharsetu:gharsetu_dev_pw@localhost:5433/gharsetu?schema=public

# Redis (BullMQ — used from Phase 4 onward; not required in Phase 0)
# docker-compose maps Redis 7 to host port 6380.
REDIS_URL=redis://localhost:6380

# ---- Web (apps/web) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
