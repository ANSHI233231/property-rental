# apps/web — environment variables for local development.
# Copy to `apps/web/.env.local` before running `pnpm --filter @gharsetu/web dev`.
# `.env.local` is gitignored (see root .gitignore). Never commit real values.

# Base URL of the NestJS API. Used by the in-browser fetch wrapper in
# apps/web/src/lib/api/client.ts. Must include the /api/v1 prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
