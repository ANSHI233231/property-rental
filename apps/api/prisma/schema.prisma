// GharSetu — Prisma schema (Phase 5 → v2: int IDs + smallint enums)
// Step 2 of the CUID→BIGINT / string-enum→smallint refactor.
// The live DB was migrated by 01-int-id-and-enum.sql (already applied).
//
// Enum code conventions (permanent contract):
//   Role:                       ADMIN=0  PROPERTY_MANAGER=1  MAINTENANCE=2  TENANT=3
//   UnitState:                  AVAILABLE=0  LISTED=1  OCCUPIED=2  MAINTENANCE=3
//   LeaseStatus:                ACTIVE=0     EXPIRED=1 RENEWED=2   TERMINATED=3
//   RentPeriodStatus:           UPCOMING=0   DUE=1     PARTIAL=2   PAID=3     OVERDUE=4 PREPAID=5
//   MaintenanceStatus:          OPEN=0       ASSIGNED=1 IN_PROGRESS=2 RESOLVED=3 CLOSED=4
//   MaintenancePriority:        LOW=0        NORMAL=1  HIGH=2      EMERGENCY=3
//   PaymentMethod:              CASH=0       BANK_TRANSFER=1 UPI=2 CHEQUE=3   OTHER=4
//   TerminationApprovalStatus:  PENDING=0    APPROVED=1 REJECTED=2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

/// All human actors in the system. No public sign-up (BL-public-signup).
/// Passwords stored as Argon2id hashes (SRS §11.1 supersedes API-spec bcrypt mention).
/// role: ADMIN=0 PROPERTY_MANAGER=1 MAINTENANCE=2 TENANT=3
model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  phone            String?   @unique
  /// Display name = first_name + " " + last_name. Auto-populated by the
  /// service on every write. Kept as a single column for back-compat with
  /// existing queries and serializations.
  name             String
  /// User's first name. Required on create (concatenated with last_name).
  first_name       String?
  /// User's last name. Optional in storage; required on create per spec.
  last_name        String?
  /// Maintenance staff specialization, e.g. "Plumber", "Electrician".
  /// Only populated when role = 2 (MAINTENANCE). Service rejects otherwise.
  specialization   String?
  password_hash    String
  /// 0=ADMIN 1=PROPERTY_MANAGER 2=MAINTENANCE 3=TENANT
  role             Int       @default(3)
  is_active        Boolean   @default(true)
  /// Nullable for the bootstrap Admin (no creator).
  created_by_user_id Int?

  /// Account lockout support (BL-lockout, enforced in AuthService).
  failed_login_count Int       @default(0)
  locked_until       DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  created_by      User?          @relation("CreatedByUser", fields: [created_by_user_id], references: [id])
  created_users   User[]         @relation("CreatedByUser")
  refresh_tokens  RefreshToken[]
  password_reset_tokens PasswordResetToken[]

  // Phase 2 relations
  managed_property  Property?   @relation("PropertyManager")
  transfer_logs_from PropertyTransferLog[] @relation("TransferFromPM")
  transfer_logs_to   PropertyTransferLog[] @relation("TransferToPM")
  transfer_logs_actor PropertyTransferLog[] @relation("TransferActor")
  audit_logs        AuditLog[]  @relation("AuditActor")
  retired_units     Unit[]      @relation("RetiredByUser")
  created_properties Property[] @relation("PropertyCreatedBy")

  // Phase 3 relations
  tenant            Tenant?
  signed_leases     Lease[]     @relation("LeaseSignedByPM")
  deposit_refunds_processed DepositRefund[] @relation("DepositRefundProcessedBy")

  // Phase 4 relations
  payments_recorded Payment[]   @relation("PaymentRecordedBy")
  payments_voided   Payment[]   @relation("PaymentVoidedBy")

  // Phase 5 relations
  maintenance_requests_raised      MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenance_requests_assigned    MaintenanceRequest[] @relation("MaintenanceAssignedTo")
  maintenance_requests_closed      MaintenanceRequest[] @relation("MaintenanceClosedBy")
  maintenance_alerts_tenant        MaintenanceAlert[]   @relation("MaintenanceAlertTenant")
  maintenance_alerts_dismissed_by  MaintenanceAlert[]   @relation("MaintenanceAlertDismissedBy")

  // Change 5 relations
  rent_change_schedules_created    RentChangeSchedule[] @relation("RentChangeScheduleCreatedBy")

  @@map("users")
}

// ---------------------------------------------------------------------------
// RefreshToken
// ---------------------------------------------------------------------------

/// Server-stored refresh tokens. Enables revocation.
/// Plain token is NEVER stored — only sha256(token) is stored here.
model RefreshToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user_agent String?
  ip         String?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, revoked_at])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// PasswordResetToken
// ---------------------------------------------------------------------------

/// Single-use, 30-minute TTL password reset tokens.
/// Plain token is NEVER stored — only sha256(token) is stored here.
model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Property
// ---------------------------------------------------------------------------

/// A physical building managed by one PROPERTY_MANAGER at a time (BL-19).
/// soft-delete: add deleted_at. No hard deletes (BL-05).
model Property {
  id          Int      @id @default(autoincrement())
  name        String
  /// Full street address stored as a single text field for flexibility.
  address     String
  city        String
  /// Indian state, stored as text (e.g. "Delhi", "Maharashtra").
  state       String
  pincode     String   @db.Char(6)
  /// IANA timezone string. Default: Asia/Kolkata (BL-22).
  timezone    String   @default("Asia/Kolkata")

  /// Current assigned PROPERTY_MANAGER. Nullable (unassigned).
  /// @unique here satisfies Prisma's one-to-one constraint requirement.
  /// A separate migration drops this standard unique and replaces it with a
  /// partial unique index WHERE active_pm_id IS NOT NULL — enforcing BL-19
  /// while allowing multiple properties to have no PM (active_pm_id = NULL).
  active_pm_id Int?    @unique

  /// Soft-delete support. Set to non-null to hide from normal queries.
  deleted_at   DateTime?

  created_by_user_id Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relations
  active_pm    User?    @relation("PropertyManager", fields: [active_pm_id], references: [id])
  created_by   User     @relation("PropertyCreatedBy", fields: [created_by_user_id], references: [id])
  units        Unit[]
  transfer_logs PropertyTransferLog[]

  @@map("properties")
}

// ---------------------------------------------------------------------------
// Unit
// ---------------------------------------------------------------------------

/// A single rentable unit within a property.
/// monthly_rent stored as Int (paise). 1 INR = 100 paise. ₹18,000 = 1_800_000 paise.
/// is_retired is one-way (BL-05): set true, never reset to false.
/// A DB trigger enforces this at the Postgres level (see migration SQL).
/// state: AVAILABLE=0 LISTED=1 OCCUPIED=2 MAINTENANCE=3
model Unit {
  id          Int       @id @default(autoincrement())
  property_id Int
  unit_number String
  floor       Int?
  bedrooms    Int
  bathrooms   Int
  area_sqft   Int?
  /// Stored in paise to avoid float math. ₹1 = 100 paise (BL-13, BL-03).
  monthly_rent_paise Int
  /// 0=AVAILABLE 1=LISTED 2=OCCUPIED 3=MAINTENANCE
  state       Int       @default(0)
  is_retired  Boolean   @default(false)
  retired_at  DateTime?
  retired_by_user_id Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  // Relations
  property    Property  @relation(fields: [property_id], references: [id])
  retired_by  User?     @relation("RetiredByUser", fields: [retired_by_user_id], references: [id])
  leases      Lease[]

  // Phase 5 relations
  maintenance_requests MaintenanceRequest[]
  maintenance_alerts   MaintenanceAlert[]

  // Change 5 relations
  rent_change_schedules RentChangeSchedule[]

  /// Unique unit number per property (e.g. can have "3B" in two different properties).
  @@unique([property_id, unit_number])
  @@index([state])
  @@map("units")
}

// ---------------------------------------------------------------------------
// PropertyTransferLog
// ---------------------------------------------------------------------------

/// Append-only record of every property manager transfer (BL-20).
/// The previous PM keeps read_only_audit access (enforced at service layer).
model PropertyTransferLog {
  id          Int      @id @default(autoincrement())
  property_id Int
  from_pm_id  Int?
  to_pm_id    Int?
  /// Admin who executed the transfer.
  actor_id    Int
  note        String?
  created_at  DateTime @default(now())

  property Property  @relation(fields: [property_id], references: [id])
  from_pm  User?     @relation("TransferFromPM", fields: [from_pm_id], references: [id])
  to_pm    User?     @relation("TransferToPM", fields: [to_pm_id], references: [id])
  actor    User      @relation("TransferActor", fields: [actor_id], references: [id])

  @@index([property_id, created_at])
  @@map("property_transfer_logs")
}

// ---------------------------------------------------------------------------
// AuditLog
// ---------------------------------------------------------------------------

/// Append-only audit trail for every state change in the system (BL-22, BL-23).
/// Written within the same Prisma $transaction as the mutation — never stand-alone.
/// No UPDATE or DELETE is ever issued on this table.
/// SPECIAL: actor_id is BIGINT FK but entity_id stays TEXT (polymorphic; legacy
/// rows reference CUIDs, new rows store int-as-string).
model AuditLog {
  id          Int      @id @default(autoincrement())
  /// Nullable — null for unauthenticated events such as auth.login.failure
  /// where no valid user is identified. Phase 7 addition.
  actor_id    Int?
  /// Actor's role at the time of the event (snapshot, not derived).
  /// Auto-populated by trg_audit_log_fill_actor_role BEFORE INSERT trigger
  /// when actor_id is present and actor_role isn't already supplied.
  /// Codes: 0=ADMIN 1=PROPERTY_MANAGER 2=MAINTENANCE 3=TENANT
  actor_role  Int?
  /// Human-readable action key e.g. 'property.create', 'unit.state_change'.
  action      String
  entity_type String
  /// Kept as String — polymorphic; pre-migration rows are CUIDs, new rows are int-as-string.
  entity_id   String
  /// JSONB snapshot before the change. Null for create operations.
  before      Json?
  /// JSONB snapshot after the change. Null for delete-style operations (none in v1).
  after       Json?
  created_at  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actor_id], references: [id])

  @@index([actor_id, created_at])
  @@index([entity_type, entity_id])
  @@index([action, created_at])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Tenant  (Phase 3)
// ---------------------------------------------------------------------------

/// Personal-info extension for User accounts with role=TENANT (role=3).
/// 1:1 with User. Created inside the same transaction as Lease signing.
model Tenant {
  id                      Int       @id @default(autoincrement())
  user_id                 Int       @unique
  dob                     DateTime? @db.Date
  id_proof_type           String?
  id_proof_number         String?
  emergency_contact_name  String?
  emergency_contact_phone String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  // Relations
  user                        User                         @relation(fields: [user_id], references: [id])
  lease_tenants               LeaseTenant[]
  termination_requests        LeaseTermination[]           @relation("TerminationRequester")
  termination_approvals       LeaseTerminationApproval[]
  deposit_refunds_received    DepositRefund[]              @relation("DepositRefundPaidTo")

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Lease  (Phase 3)
// ---------------------------------------------------------------------------

/// A rental agreement between a property manager and one or more tenants.
/// BL-01: at most one ACTIVE lease per unit (partial unique index in migration).
/// BL-02: monthly_rent_paise and security_deposit_paise are immutable (DB trigger).
/// status: ACTIVE=0 EXPIRED=1 RENEWED=2 TERMINATED=3
model Lease {
  id                       Int         @id @default(autoincrement())
  unit_id                  Int
  start_date               DateTime    @db.Date
  end_date                 DateTime    @db.Date
  /// Stored in paise (BigInt). BL-02: immutable after creation.
  monthly_rent_paise       BigInt
  /// Stored in paise (BigInt). BL-02: immutable after creation.
  security_deposit_paise   BigInt
  /// Placeholder for Phase 4. Default 0 means no daily late fee configured yet.
  late_fee_per_day_paise   BigInt      @default(0)
  /// 0=ACTIVE 1=EXPIRED 2=RENEWED 3=TERMINATED
  status                   Int         @default(0)
  signed_by_pm_id          Int
  signed_at                DateTime    @default(now())
  terminated_at            DateTime?
  created_at               DateTime    @default(now())
  updated_at               DateTime    @updatedAt

  // Relations
  unit            Unit              @relation(fields: [unit_id], references: [id])
  signed_by_pm    User              @relation("LeaseSignedByPM", fields: [signed_by_pm_id], references: [id])
  lease_tenants   LeaseTenant[]
  terminations    LeaseTermination[]
  deposit_refund  DepositRefund?

  // Phase 4 relations
  rent_periods    RentPeriod[]
  payments        Payment[]         @relation("PaymentLease")
  prepaid_credits PrepaidCredit[]   @relation("PrepaidCreditLease")

  // Phase 5 relations
  maintenance_requests MaintenanceRequest[]

  @@index([unit_id, status])
  @@index([end_date])
  @@map("leases")
}

// ---------------------------------------------------------------------------
// LeaseTenant  (Phase 3)
// ---------------------------------------------------------------------------

/// Join table: which Tenants are on which Lease, and which is the primary.
/// BL-07: at least one tenant required (enforced at service layer).
model LeaseTenant {
  id          Int       @id @default(autoincrement())
  lease_id    Int
  tenant_id   Int
  is_primary  Boolean   @default(false)
  joined_at   DateTime  @default(now())
  removed_at  DateTime?

  lease  Lease  @relation(fields: [lease_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([lease_id, tenant_id])
  @@map("lease_tenants")
}

// ---------------------------------------------------------------------------
// LeaseTermination  (Phase 3)
// ---------------------------------------------------------------------------

/// A termination request for a lease. Only one open request per lease at a time.
/// "Open" = finalized_at IS NULL AND withdrawn_at IS NULL.
/// The partial unique index is in the raw migration SQL (Prisma cannot express it).
model LeaseTermination {
  id                    Int       @id @default(autoincrement())
  lease_id              Int
  requested_by_tenant_id Int
  requested_at          DateTime  @default(now())
  reason                String?
  withdrawn_at          DateTime?
  finalized_at          DateTime?
  /// The calendar date on which the lease actually ends.
  effective_date        DateTime  @db.Date

  // Relations
  lease              Lease                      @relation(fields: [lease_id], references: [id])
  requested_by       Tenant                     @relation("TerminationRequester", fields: [requested_by_tenant_id], references: [id])
  approvals          LeaseTerminationApproval[]

  @@index([lease_id])
  @@map("lease_terminations")
}

// ---------------------------------------------------------------------------
// LeaseTerminationApproval  (Phase 3)
// ---------------------------------------------------------------------------

/// Per-co-tenant approval row for a termination request.
/// BL-08 / BL-09: all co-tenants must APPROVE before finalize is allowed.
/// status: PENDING=0 APPROVED=1 REJECTED=2
model LeaseTerminationApproval {
  id              Int       @id @default(autoincrement())
  termination_id  Int
  tenant_id       Int
  /// 0=PENDING 1=APPROVED 2=REJECTED
  status          Int       @default(0)
  responded_at    DateTime?
  note            String?

  termination LeaseTermination @relation(fields: [termination_id], references: [id])
  tenant      Tenant           @relation(fields: [tenant_id], references: [id])

  @@unique([termination_id, tenant_id])
  @@index([termination_id])
  @@map("lease_termination_approvals")
}

// ---------------------------------------------------------------------------
// DepositRefund  (Phase 3)
// ---------------------------------------------------------------------------

/// Security deposit refund record. At most one per lease (unique on lease_id in migration).
/// Lease must be TERMINATED before a refund can be processed.
model DepositRefund {
  id                  Int      @id @default(autoincrement())
  lease_id            Int      @unique
  amount_paise        BigInt
  deductions_paise    BigInt   @default(0)
  deduction_reason    String?
  paid_to_tenant_id   Int
  processed_by_pm_id  Int
  processed_at        DateTime
  created_at          DateTime @default(now())

  lease          Lease  @relation(fields: [lease_id], references: [id])
  paid_to_tenant Tenant @relation("DepositRefundPaidTo", fields: [paid_to_tenant_id], references: [id])
  processed_by   User   @relation("DepositRefundProcessedBy", fields: [processed_by_pm_id], references: [id])

  @@map("deposit_refunds")
}

// ---------------------------------------------------------------------------
// RentPeriod  (Phase 4)
// ---------------------------------------------------------------------------

/// One calendar-month billing period for a lease.
/// BL-12: status flips to OVERDUE exactly 5 calendar days past due_date (BullMQ worker).
/// BL-13: late_fee_paise accrues weekly at 2% × amount_due_paise × floor_weeks_overdue.
/// outstanding_paise is service-computed (amount_due + late_fee - paid) and stored for
/// efficient queries; updated transactionally whenever paid_paise or late_fee_paise changes.
/// Unique (lease_id, period_start): prevents duplicate periods.
/// status: UPCOMING=0 DUE=1 PARTIAL=2 PAID=3 OVERDUE=4 PREPAID=5
model RentPeriod {
  id               Int              @id @default(autoincrement())
  lease_id         Int
  period_start     DateTime         @db.Date
  period_end       DateTime         @db.Date
  due_date         DateTime         @db.Date
  /// Snapshotted from lease.monthly_rent_paise at period creation time.
  amount_due_paise BigInt
  paid_paise       BigInt           @default(0)
  /// Stored: amount_due_paise - paid_paise (no fee). The late fee is NOT
  /// persisted — it is computed on read via @gharsetu/shared's
  /// computeLateFeePaise(amount_due_paise, daysOverdue) and added back
  /// in the response. See rent.service.ts → serializePeriod.
  outstanding_paise BigInt          @default(0)
  /// 0=UPCOMING 1=DUE 2=PARTIAL 3=PAID 4=OVERDUE 5=PREPAID
  status           Int              @default(1)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  // Relations
  lease    Lease     @relation(fields: [lease_id], references: [id])
  payments Payment[] @relation("PaymentPeriod")

  @@unique([lease_id, period_start])
  @@index([status, due_date])
  @@index([lease_id, period_start(sort: Desc)])
  @@map("rent_periods")
}

// ---------------------------------------------------------------------------
// Payment  (Phase 4)
// ---------------------------------------------------------------------------

/// Append-only payment records. BL-10: only PM/Admin may create.
/// DB-level BEFORE DELETE and BEFORE UPDATE triggers enforce immutability
/// (only is_voided / voided_by / voided_at / void_reason columns may change).
/// method: CASH=0 BANK_TRANSFER=1 UPI=2 CHEQUE=3 OTHER=4
model Payment {
  id                  Int           @id @default(autoincrement())
  rent_period_id      Int
  /// Denormalized for fast lookups without joining through RentPeriod.
  lease_id            Int
  amount_paise        BigInt
  /// 0=CASH 1=BANK_TRANSFER 2=UPI 3=CHEQUE 4=OTHER
  method              Int
  reference           String?
  /// The date the tenant physically paid (may be before recorded_at).
  paid_on             DateTime      @db.Date
  recorded_by_user_id Int
  recorded_at         DateTime      @default(now())
  is_voided           Boolean       @default(false)
  voided_by_user_id   Int?
  voided_at           DateTime?
  void_reason         String?
  created_at          DateTime      @default(now())
  /// Phase 7: Idempotency key supplied by the caller (Idempotency-Key HTTP header).
  /// Unique partial index (WHERE idempotency_key IS NOT NULL) prevents duplicate
  /// payments on network retry. Nullable — absent when caller does not supply header.
  idempotency_key     String?

  // Relations
  rent_period      RentPeriod       @relation("PaymentPeriod", fields: [rent_period_id], references: [id])
  lease            Lease            @relation("PaymentLease", fields: [lease_id], references: [id])
  recorded_by      User             @relation("PaymentRecordedBy", fields: [recorded_by_user_id], references: [id])
  voided_by        User?            @relation("PaymentVoidedBy", fields: [voided_by_user_id], references: [id])
  /// Credit produced by this payment's excess (spillover).
  prepaid_credit_sourced PrepaidCredit? @relation("SourcePayment")
  /// Credit consumed by this payment (when prepaid balance was applied).
  prepaid_credit_consumed PrepaidCredit? @relation("ConsumedByPayment")

  @@index([lease_id, recorded_at])
  @@index([rent_period_id])
  @@index([idempotency_key])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// PrepaidCredit  (Phase 4)
// ---------------------------------------------------------------------------

/// Excess payment spillover applied to future periods.
/// Per §11.4: PrepaidCredit is a separate table, not a column on RentPeriod.
/// FIFO consumption: earliest created_at is consumed first.
/// Multiple unconsumed credits may coexist for the same lease.
model PrepaidCredit {
  id                     Int       @id @default(autoincrement())
  lease_id               Int
  source_payment_id      Int       @unique
  amount_paise           BigInt
  consumed_at            DateTime?
  consumed_by_payment_id Int?      @unique
  created_at             DateTime  @default(now())

  // Relations
  lease              Lease    @relation("PrepaidCreditLease", fields: [lease_id], references: [id])
  source_payment     Payment  @relation("SourcePayment", fields: [source_payment_id], references: [id])
  consumed_by_payment Payment? @relation("ConsumedByPayment", fields: [consumed_by_payment_id], references: [id])

  @@index([lease_id, created_at])
  @@map("prepaid_credits")
}

// ---------------------------------------------------------------------------
// MaintenanceRequest  (Phase 5)
// ---------------------------------------------------------------------------

/// A maintenance request raised by a tenant for their unit.
/// BL-14: description >= 30 chars; resolution_notes >= 20 chars (both enforced by DB CHECK).
/// BL-15: once closed_at is set the row is immutable (DB BEFORE UPDATE trigger).
/// BL-16: MAINTENANCE role may not create requests (service-layer + @Roles guard).
/// BL-21: only the original raising tenant may close a request (service-layer check).
/// status: OPEN=0 ASSIGNED=1 IN_PROGRESS=2 RESOLVED=3 CLOSED=4
/// priority: LOW=0 NORMAL=1 HIGH=2 EMERGENCY=3
model MaintenanceRequest {
  id                    Int               @id @default(autoincrement())
  unit_id               Int
  /// Denormalized from the unit's active lease at create time. Nullable for edge cases.
  lease_id              Int?
  raised_by_user_id     Int
  assigned_to_user_id   Int?
  title                 String            @db.VarChar(120)
  /// BL-14: minimum 30 characters (DB CHECK enforced in migration SQL).
  description           String
  /// 0=LOW 1=NORMAL 2=HIGH 3=EMERGENCY
  priority              Int               @default(1)
  /// 0=OPEN 1=ASSIGNED 2=IN_PROGRESS 3=RESOLVED 4=CLOSED
  status                Int               @default(0)
  /// BL-14: minimum 20 characters when set (DB CHECK enforced in migration SQL).
  resolution_notes      String?
  assigned_at           DateTime?
  in_progress_at        DateTime?
  resolved_at           DateTime?
  closed_at             DateTime?
  /// BL-21: only TENANT closes. Populated on close.
  closed_by_user_id     Int?
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  // Relations
  unit          Unit   @relation(fields: [unit_id], references: [id])
  lease         Lease? @relation(fields: [lease_id], references: [id])
  raised_by     User   @relation("MaintenanceRaisedBy", fields: [raised_by_user_id], references: [id])
  assigned_to   User?  @relation("MaintenanceAssignedTo", fields: [assigned_to_user_id], references: [id])
  closed_by     User?  @relation("MaintenanceClosedBy", fields: [closed_by_user_id], references: [id])

  @@index([unit_id, created_at(sort: Desc)])
  @@index([lease_id, created_at])
  @@map("maintenance_requests")
}

// ---------------------------------------------------------------------------
// MaintenanceAlert  (Phase 5 — BL-17)
// ---------------------------------------------------------------------------

/// BL-17: triggered when a tenant has >= 5 maintenance requests for the same unit
/// in a single calendar month (Asia/Kolkata). Unique per (tenant, unit, month_key).
/// Dismissed by Admin or PM; dismissal does not delete the row.
model MaintenanceAlert {
  id                    Int       @id @default(autoincrement())
  tenant_user_id        Int
  unit_id               Int
  /// YYYY-MM in Asia/Kolkata timezone (e.g. '2026-05').
  month_key             String
  request_count         Int
  triggered_at          DateTime
  dismissed_at          DateTime?
  dismissed_by_user_id  Int?
  dismiss_note          String?
  created_at            DateTime  @default(now())

  // Relations
  tenant       User  @relation("MaintenanceAlertTenant", fields: [tenant_user_id], references: [id])
  unit         Unit  @relation(fields: [unit_id], references: [id])
  dismissed_by User? @relation("MaintenanceAlertDismissedBy", fields: [dismissed_by_user_id], references: [id])

  /// One alert per tenant/unit/month — idempotent upsert.
  @@unique([tenant_user_id, unit_id, month_key])
  @@index([unit_id, month_key])
  @@map("maintenance_alerts")
}

// ---------------------------------------------------------------------------
// RentAccrualLog  (Phase 4)
// ---------------------------------------------------------------------------

/// BullMQ worker run log. One row per calendar date (IST).
/// BL-13 idempotency: if finished_at IS NOT NULL for today, worker skips.
model RentAccrualLog {
  id                     Int       @id @default(autoincrement())
  run_date               DateTime  @db.Date @unique
  started_at             DateTime  @default(now())
  finished_at            DateTime?
  periods_examined       Int       @default(0)
  periods_overdue_flipped Int      @default(0)
  late_fees_added_paise  BigInt    @default(0)
  next_periods_generated Int       @default(0)
  error                  String?
  created_at             DateTime  @default(now())

  @@map("rent_accrual_log")
}

// ---------------------------------------------------------------------------
// RentChangeSchedule  (Change 5)
// ---------------------------------------------------------------------------

/// Scheduled rent changes. A PM picks a new monthly rent and an effective date
/// (must be >= 60 calendar days from creation). On the effective date, the
/// rent-change-apply cron sets the unit's monthly_rent_paise to the new value
/// and flips status to APPLIED.
///
/// At most ONE PENDING schedule per unit at a time (enforced by partial unique
/// index rent_change_schedules_one_pending_per_unit in migration SQL).
///
/// status: PENDING=0  CANCELLED=1  APPLIED=2
model RentChangeSchedule {
  id                 Int       @id @default(autoincrement())
  unit_id            Int
  new_amount_paise   BigInt
  effective_date     DateTime  @db.Date
  /// 0=PENDING 1=CANCELLED 2=APPLIED
  status             Int       @default(0)
  created_by_user_id Int
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  /// When the cron applied this schedule. Null until applied.
  applied_at         DateTime?
  /// When the PM cancelled this schedule. Null unless cancelled.
  cancelled_at       DateTime?

  unit       Unit @relation(fields: [unit_id], references: [id])
  created_by User @relation("RentChangeScheduleCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([unit_id, status])
  @@map("rent_change_schedules")
}
