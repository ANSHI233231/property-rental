# GharSetu API — environment variable template
# Copy to .env and fill in real values. DO NOT commit .env to git.

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000
# Public origin where the FE is served. Used to build absolute URLs sent in
# emails (e.g. password-reset links). Must be reachable by end users.
FRONTEND_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://gharsetu:CHANGE_ME@localhost:5432/gharsetu?schema=public

# ── Scheduler ───────────────────────────────────────────────────────────────
# Set to 'false' on additional API replicas to disable in-process cron jobs.
# Default (unset or 'true') enables @nestjs/schedule cron jobs.
# RUN_SCHEDULER=true

# ── JWT ─────────────────────────────────────────────────────────────────────
# HS256 secret — minimum 32 random bytes. Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Seed ────────────────────────────────────────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
SEED_TEST_PASSWORD=CHANGE_ME

# ── Email / SMTP (Change 5 — scheduled rent change notifications) ────────────
# If any of the five SMTP_* vars are missing, EmailService runs in log-only mode:
# emails are logged to stdout but not sent. This is the correct behaviour for
# local development and CI environments without a real SMTP server.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="GharSetu <no-reply@example.com>"
