{
  "name": "@gharsetu/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types, enums, and constants consumed by apps/web and apps/api.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint configured for shared yet)\"",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
