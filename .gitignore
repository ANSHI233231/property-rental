# Third-party Claude skills (managed locally per-developer)
# Install from upstream: https://github.com/nextlevelbuilder/ui-ux-pro-max-skill
# (use /* not / so project-owned skills below can be re-included)
.claude/skills/*
# Exception: project-owned skills (gharsetu-*) are checked in for the team
!.claude/skills/gharsetu-*/

# Stale prototype archives (extracted to prototype/ folder)
prototype.zip

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment (never commit real secrets — see .env.example for the template)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Build outputs
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo

# Playwright
apps/web/test-results/
apps/web/playwright-report/
apps/web/.playwright/

# Database backups (PG dumps written during VAPT / regression runs)
backups/

# Draft / one-off migration SQL — never committed.
apps/api/prisma/drafts/

# Prisma generated client (regenerated on install)
apps/api/src/generated/
apps/api/prisma/migrations/dev.db*

# Turbo / Next.js / pnpm caches
.turbo/
.pnpm-store/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/
